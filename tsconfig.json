{
    "compilerOptions": {
        "target": "ES2020", // Modern JS output
        "module": "esnext", // Node-compatible module system
        "moduleResolution": "bundler", // Modern module resolution strategy
        "lib": ["ES2020"], // Include modern JS features
        "types": ["node", "playwright"], // Add Node + Playwright type definitions
        "esModuleInterop": true, // Allow default imports from CommonJS
        "resolveJsonModule": true, // Import JSON files directly
        "allowJs": false, // Keep project strictly TypeScript
        "strict": true, // Enable all strict type checks
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true, // Skip type checking of dependencies
        "outDir": "dist" // Compiled output folder
    },
    "exclude": ["node_modules", "dist"] // Ignore build + dependencies
}
